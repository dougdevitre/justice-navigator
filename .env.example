# Justice Navigator Configuration
# Copy this file to .env and fill in your values

# Application environment (development | staging | production)
NODE_ENV=development

# Server port
PORT=3000

# PostgreSQL connection string for journey and case data
DATABASE_URL=postgresql://localhost:5432/justice_navigator

# Redis connection string for session and position caching
REDIS_URL=redis://localhost:6379

# API key for authenticating external service calls
API_KEY=your-api-key-here
